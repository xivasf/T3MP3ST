{
  "name": "t3mp3st",
  "version": "1.0.0",
  "description": "Tactical Execution Multi-agent Platform for Elite Security Testing",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "setup": "tsx src/setup.ts",
    "setup:api": "bash scripts/setup-api.sh",
    "doctor": "node scripts/doctor.mjs",
    "verify-claims": "node scripts/verify-claims.mjs",
    "bench:model-matrix": "node scripts/model-matrix.mjs",
    "verify:model-matrix": "node scripts/model-matrix.mjs --verify",
    "test:model-matrix": "node scripts/model-matrix.mjs --self-test && node scripts/test-model-matrix.mjs",
    "disclose": "node scripts/disclosure-gen.mjs",
    "test:disclose": "node scripts/test-disclosure-gen.mjs",
    "verify-finding": "node scripts/verify-finding.mjs",
    "test:verify": "node scripts/test-verify-finding.mjs",
    "test:fallback": "node scripts/test-model-fallback.mjs",
    "server": "tsx src/server.ts",
    "server:prod": "node dist/server.js",
    "field:drill": "node scripts/field-drill.mjs",
    "exploit:smoke": "node scripts/exploit-chain-smoke.mjs",
    "arsenal:smoke": "node scripts/arsenal-smoke.mjs",
    "arsenal:doctor": "node scripts/arsenal-doctor.mjs",
    "prompt:audit": "node scripts/prompt-audit.mjs",
    "cve:bench": "node scripts/cve-hunt-bench.mjs",
    "cve:bench:live": "node scripts/cve-hunt-bench.mjs --live",
    "cve:bench:adversarial": "node scripts/cve-hunt-bench.mjs --adversarial",
    "cloud:bench": "node scripts/cloud-misconfig-bench.mjs",
    "cloud:bench:live": "node scripts/cloud-misconfig-bench.mjs --live",
    "mobile:bench": "node scripts/mobile-static-bench.mjs",
    "binary:bench": "node scripts/binary-vuln-bench.mjs",
    "keys": "bash scripts/keys.sh",
    "keys:list": "bash scripts/keys.sh list",
    "obsidivm": "node scripts/obsidivm-bridge.mjs",
    "obsidivm:spec": "node scripts/obsidivm-bridge.mjs spec",
    "obsidivm:bench": "node scripts/obsidivm-bench.mjs",
    "obsidivm:bench:stub": "node scripts/obsidivm-bench.mjs --hunter stub",
    "obsidivm:bench:live": "node scripts/obsidivm-bench.mjs --hunter live",
    "obsidivm:bench:t3mp3st": "node scripts/obsidivm-bench.mjs --hunter t3mp3st",
    "obsidivm:agent": "node scripts/obsidivm-agent.mjs",
    "obsidivm:evolve": "node scripts/obsidivm-evolve.mjs",
    "obsidivm:evolve:reset": "node scripts/obsidivm-evolve.mjs --reset",
    "obsidivm:replay": "node scripts/obsidivm-replay.mjs",
    "obsidivm:ablate": "node scripts/obsidivm-ablate.mjs",
    "cybench": "node scripts/cybench-bench.mjs",
    "cybench:live": "node scripts/cybench-bench.mjs --hunter live",
    "test:flag-grading": "node scripts/test-flag-grading.mjs",
    "test:cybench-ci": "node scripts/test-cybench-ci.mjs",
    "tools:check": "bash scripts/check-tools-image.sh",
    "tools:build": "bash tools/build.sh",
    "install:tools": "bash scripts/install-tools.sh",
    "docs:sync": "node scripts/pagenary-docsite.mjs",
    "docs:build": "npm run docs:sync && pagenary build t3mp3st-docs",
    "docs:serve": "npm run docs:build && pagenary serve",
    "docs:preview": "npm run docs:serve",
    "docs:check": "npm run docs:build && node scripts/check-pagenary-docsite.mjs",
    "mcp": "tsx src/mcp-server.ts",
    "mcp:prod": "node dist/mcp-server.js",
    "test": "vitest run src && node scripts/test-ops-preflight.mjs && node scripts/test-model-matrix.mjs && node scripts/refusal-frontier.mjs --self-test",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest src",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "test:playbooks": "node scripts/test-playbook-routing.mjs",
    "decompose": "node scripts/decompose.mjs",
    "test:decompose": "node scripts/decompose.mjs --self-test",
    "probe:frontier": "node scripts/refusal-frontier.mjs",
    "test:frontier": "node scripts/refusal-frontier.mjs --self-test",
    "cli-hunt": "node scripts/cli-hunt.mjs",
    "test:cli-hunt": "node scripts/cli-hunt.mjs --self-test",
    "swarm": "node scripts/cli-swarm.mjs",
    "test:swarm": "node scripts/cli-swarm.mjs --self-test",
    "test:no-fitting": "node scripts/test-no-fitting.mjs",
    "test:autodetect": "node scripts/test-autodetect.mjs",
    "test:arsenal-tools": "node scripts/test-arsenal-tools.mjs",
    "lessons": "node scripts/lessons.mjs",
    "test:lessons": "node scripts/lessons.mjs --self-test",
    "test:no-self-fitting": "node scripts/test-no-self-fitting.mjs",
    "test:no-phantom-tools": "vitest run src/__tests__/no-phantom-tools.test.ts",
    "test:spine-live": "vitest run src/__tests__/spine-live.test.ts",
    "smoke": "node scripts/smoke.mjs",
    "smoke:live": "node scripts/smoke.mjs --live",
    "capability": "node scripts/capability-smoke.mjs",
    "gauntlet": "node scripts/capability-smoke.mjs --gauntlet",
    "test:gate": "npm run build --silent && node scripts/test-gate.mjs",
    "ops:preflight": "node scripts/ops-preflight.mjs",
    "test:ops-preflight": "node scripts/test-ops-preflight.mjs",
    "update": "node scripts/update.mjs",
    "update:dry": "node scripts/update.mjs --dry-run",
    "update:hard": "node scripts/update.mjs --hard",
    "test:update": "node scripts/test-update.mjs"
  },
  "bin": {
    "tempest": "./dist/cli.js",
    "t3mp3st": "./dist/cli.js"
  },
  "keywords": [
    "penetration-testing",
    "security",
    "red-team",
    "multi-agent",
    "ai",
    "llm"
  ],
  "author": "t3mp3st contributors",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elder-plinius/t3mp3st.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "ajv": "^8.20.0",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^12.1.0",
    "conf": "^12.0.0",
    "cors": "^2.8.5",
    "cross-spawn": "^7.0.6",
    "dotenv": "^16.4.5",
    "eventemitter3": "^5.0.1",
    "express": "^4.18.2",
    "figlet": "^1.7.0",
    "gradient-string": "^2.0.2",
    "inquirer": "^9.2.15",
    "ora": "^8.0.1",
    "socks": "^2.8.9",
    "tree-sitter-wasms": "0.1.13",
    "tsx": "^4.7.0",
    "undici": "^8.7.0",
    "web-tree-sitter": "0.25.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@pagenary/publisher": "^2026.7.24",
    "@types/cors": "^2.8.17",
    "@types/cross-spawn": "^6.0.6",
    "@types/express": "^4.17.21",
    "@types/figlet": "^1.5.8",
    "@types/gradient-string": "^1.1.5",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "^9.39.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.51.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "qs": "^6.15.2",
    "hono": "^4.12.25",
    "js-yaml": "^4.2.0"
  }
}
